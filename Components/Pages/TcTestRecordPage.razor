@page "/tc/test-record"
@inject NavigationManager Navigation

<div class="page-container">
    <div class="win11-card test-card-tc" @onclick='() => Navigation.NavigateTo("/tc/person-select")'>
        <span class="card-label">测试</span>
    </div>
    <div class="win11-card record-card-tc" @onclick='() => Navigation.NavigateTo("/tc/records")'>
        <span class="card-label">记录</span>
    </div>
    <button class="btn-full-width btn-return" @onclick='() => Navigation.NavigateTo("/")'>返回</button>
</div>
