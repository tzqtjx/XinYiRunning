@page "/person-select"
@inject NavigationManager Navigation
@inject AppState AppState

<div class="page-container" @onclick="OnBackgroundClick">
    <div class="page-title-row">
        <h3 class="page-title">选择人员</h3>
        @if (editMode)
        {
            <button class="btn-edit-active" @onclick:stopPropagation="true" @onclick="ShowAddDialog">添加</button>
        }
        else
        {
            <button class="btn-edit" @onclick:stopPropagation="true" @onclick="EnterEditMode">编辑</button>
        }
    </div>

    <div class="person-grid" @onclick:stopPropagation="true">
        @foreach (var person in AppState.AllPersons)
        {
            var isSelected = AppState.SelectedPersons.Contains(person);
            <div class="win11-card person-card @(isSelected ? "selected" : "")"
                 @onclick="() => HandlePersonClick(person)">
                @if (editMode)
                {
                    <span class="person-delete-x"
                          @onclick:stopPropagation="true"
                          @onclick='() => DeletePerson(person)'>×</span>
                }
                <span>@person</span>
            </div>
        }
    </div>

    @if (showAddInput)
    {
        <div class="dialog-overlay" @onclick="HideAddDialog">
            <div class="dialog-box" @onclick:stopPropagation="true">
                <input @bind="newPersonName" placeholder="输入姓名" class="dialog-input" />
                <button class="btn-black" @onclick="AddPerson" disabled="@(string.IsNullOrWhiteSpace(newPersonName))">确认</button>
                <button class="btn-secondary" @onclick="HideAddDialog">取消</button>
            </div>
        </div>
    }

    <div class="bottom-bar" @onclick:stopPropagation="true">
        <button class="btn-half btn-return" @onclick='() => Navigation.NavigateTo("/test-record")'>返回</button>
        <button class="btn-half btn-confirm" @onclick="Confirm" disabled="@(AppState.SelectedPersons.Count == 0)">确定</button>
    </div>
</div>

@code {
    private bool showAddInput;
    private string newPersonName = "";
    private bool editMode;

    private void EnterEditMode() => editMode = true;

    private void OnBackgroundClick()
    {
        if (editMode) editMode = false;
    }

    private void HandlePersonClick(string person)
    {
        if (editMode) return;
        TogglePerson(person);
    }

    private void DeletePerson(string person)
    {
        AppState.AllPersons.Remove(person);
        AppState.SelectedPersons.Remove(person);
        AppState.SaveLocalPersons();
    }

    private void TogglePerson(string person)
    {
        if (AppState.SelectedPersons.Contains(person))
            AppState.SelectedPersons.Remove(person);
        else
            AppState.SelectedPersons.Add(person);
    }

    private void ShowAddDialog()
    {
        showAddInput = true;
        newPersonName = "";
    }

    private void HideAddDialog()
    {
        showAddInput = false;
        newPersonName = "";
    }

    private void AddPerson()
    {
        if (!string.IsNullOrWhiteSpace(newPersonName) && !AppState.AllPersons.Contains(newPersonName))
        {
            AppState.AllPersons.Add(newPersonName);
            AppState.SaveLocalPersons();
        }
        HideAddDialog();
    }

    private void Confirm()
    {
        Navigation.NavigateTo("/mode-select");
    }
}
